{
    "name": "goodbus-server",
    "version": "1.0.0",
    "description": "GoodBus server",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:push": "prisma db push",
        "db:seed": "tsx src/prisma/seed.ts",
        "db:clear": "tsx src/prisma/clear.ts",
        "db:reset": "tsx src/prisma/clear.ts && tsx src/prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "^5.19.1",
        "bcrypt": "^5.1.1",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.0",
        "jsonwebtoken": "^9.0.2",
        "nodemailer": "^6.9.8",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^20.14.15",
        "@types/nodemailer": "^6.4.14",
        "prisma": "^5.19.1",
        "prisma-erd-generator": "^2.1.0",
        "tsx": "^4.16.2",
        "typescript": "^5.5.4"
    }
